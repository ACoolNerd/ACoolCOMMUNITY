# Core Config
PORT=3000
NODE_ENV=development
PROJECT_TYPE=website # [website, lms, marketplace, consultant, health, media, finance, social]

# AI Endpoints
ACOOLAI_ENDPOINT=https://api.acoolai.com/v1
ACOOLAI_KEY=your_key_here
ILAI_ENDPOINT=https://api.acoolai.com/v1/enterprise
ILAI_KEY=your_key_here

# Governance
MEAP_ENFORCEMENT_LEVEL=ADVISE # [BLOCK, ADVISE, LOG]
AUDIT_LOG_PATH=./logs/audit.log

# Deployment
VERCEL_TOKEN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
